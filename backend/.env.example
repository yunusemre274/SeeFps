# SeeFps Backend — Environment Variables
# Kopyala ve `.env` olarak yeniden adlandır.

# TrainedData dizinine giden yol (varsayılan: ../TrainedData)
TRAINED_DATA_DIR=../TrainedData

# Sunucu ayarları
HOST=0.0.0.0
PORT=8000

# CORS — Frontend origin'leri (virgülle ayır)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://localhost:3000,http://localhost:3001
